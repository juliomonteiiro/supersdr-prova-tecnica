NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/supersdr

# Z-API webhook auth (optional)
# Real callbacks usually send the instance token in header `z-api-token`.
# If set, POST /webhook/zapi requires this token (fallback: ZAPI_CLIENT_TOKEN / header Client-Token).
# ZAPI_INSTANCE_TOKEN=
# ZAPI_CLIENT_TOKEN=

# LLM (optional): when OPENAI_API_KEY is set, the app classifies message intent asynchronously.
# If missing, a local keyword classifier is used as fallback.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
