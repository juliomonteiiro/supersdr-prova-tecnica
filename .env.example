NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/supersdr

# Z-API (optional): same value as "Client-Token" / security token from the Z-API panel.
# If set, incoming POST /webhook/zapi requests must include header: Client-Token: <value>
# ZAPI_CLIENT_TOKEN=

# LLM (optional): when OPENAI_API_KEY is set, the app classifies message intent asynchronously.
# If missing, a local keyword classifier is used as fallback.
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
